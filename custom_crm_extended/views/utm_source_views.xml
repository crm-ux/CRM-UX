<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="utm_source_view_list" model="ir.ui.view">
        <field name="name">utm.source.view.list</field>
        <field name="model">utm.source</field>
        <field name="arch" type="xml">
            <list string="Lead Sources" editable="bottom">
                <field name="name" string="Source Name"/>
            </list>
        </field>
    </record>

    <record id="action_utm_source_manage" model="ir.actions.act_window">
        <field name="name">Lead Sources</field>
        <field name="res_model">utm.source</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_utm_source_manage" name="Lead Sources"
        parent="crm.crm_menu_root"
        action="action_utm_source_manage"
        sequence="20"/>
</odoo>
