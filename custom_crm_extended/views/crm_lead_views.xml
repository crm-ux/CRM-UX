<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==============================================================
         QUICK CREATE FORM  (the popup when clicking + in kanban)
         Override the default quick_create_opportunity_form
    =============================================================== -->
    <record id="view_crm_lead_quick_create_custom" model="ir.ui.view">
        <field name="name">crm.lead.quick.create.custom</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.quick_create_opportunity_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <!-- Replace entire quick create content -->
            <xpath expr="//form" position="replace">
                <form>
                    <group>
                        <!-- Row 1: Lead Name -->
                        <group col="1">
                            <field name="name"
                                   string="Lead Name"
                                   placeholder="e.g. 50 MCB Units - ABC Electricals"
                                   required="1"
                                   nolabel="1"/>
                        </group>
                        <!-- Row 2: Company + Contact -->
                        <group col="2">
                            <field name="partner_name"
                                   string="Company Name"
                                   placeholder="Company Name"/>
                            <field name="contact_name"
                                   string="Contact Person"
                                   placeholder="Contact Person"/>
                        </group>
                        <!-- Row 3: Mobile + Email -->
                        <group col="2">
                            <field name="mobile"
                                   string="Mobile"
                                   placeholder="Mobile"/>
                            <field name="email_from"
                                   string="Email"
                                   placeholder="Email"/>
                        </group>
                        <!-- Row 4: Source + Category -->
                        <group col="2">
                            <field name="source_id"
                                   string="Lead Source"
                                   options="{&quot;no_create&quot;: True}"
                                   placeholder="Lead Source"/>
                            <field name="x_customer_type"
                                   string="Customer Type"/>
                        </group>
                        <!-- Row 5: Assign To + Priority -->
                        <group col="2">
                            <field name="x_assign_to_id"
                                   string="Assign To"
                                   readonly="x_assign_to_readonly"
                                   options="{&quot;no_create&quot;: True}"
                                   placeholder="Assign to member..."/>
                            <field name="priority"
                                   string="Priority"
                                   widget="priority"/>
                        </group>
                    </group>
                    <footer>
                        <button string="Add"
                                class="btn-primary"
                                special="save"/>
                        <button string="Edit Full Form"
                                class="btn-secondary"
                                special="open"/>
                        <button string="Discard"
                                class="btn-link"
                                special="cancel"/>
                    </footer>
                </form>
            </xpath>
        </field>
    </record>


    <!-- ==============================================================
         MAIN OPPORTUNITY FORM VIEW  -  Full layout redesign
         inherit: crm.crm_lead_view_form
    =============================================================== -->
    <record id="view_crm_lead_form_custom" model="ir.ui.view">
        <field name="name">crm.lead.form.custom</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">

            <!-- Load hidden fields needed in expressions -->
            <xpath expr="//sheet" position="before">
                <field name="x_assign_to_readonly" invisible="1"/>
                <field name="x_is_refused" invisible="1"/>
                <field name="x_is_overdue" invisible="1"/>
            </xpath>

            <!-- REFUSAL ALERT BANNER -->
            <xpath expr="//header" position="inside">
                <div class="alert alert-warning mb-0 py-1 px-2"
                     invisible="not x_is_refused"
                     role="alert">
                    <i class="fa fa-exclamation-triangle me-1"/>
                    <strong>Assignment Refused</strong> by
                    <field name="x_refused_by_id" readonly="1" nolabel="1" class="oe_inline"/>
                    - Reason: <field name="x_refuse_reason" readonly="1" nolabel="1" class="oe_inline"/>
                </div>
            </xpath>

            <!-- BUTTONS: Refuse / Reset -->
            <xpath expr="//header/button[last()]" position="after">
                <button name="action_refuse_lead"
                        string="Refuse Assignment"
                        type="object"
                        class="btn-secondary"
                        invisible="not x_assign_to_id or x_is_refused"/>
                <button name="action_reset_from_refusal"
                        string="Reset Lead"
                        type="object"
                        class="btn-secondary"
                        invisible="not x_is_refused"/>
            </xpath>

            <!-- ROW 1: Lead Name (full width - already default, just improve label) -->
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="string">Lead Name</attribute>
                <attribute name="placeholder">e.g. 50 MCB Units - ABC Electricals</attribute>
            </xpath>

            <!-- ROW 2: Replace the default top group with our structured layout -->
            <!-- First move user_id label to "Lead Owner" -->
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="string">Lead Owner</attribute>
            </xpath>

            <!-- Add Assign To after Lead Owner -->
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="x_assign_to_id"
                       string="Assign To"
                       readonly="x_assign_to_readonly"
                       options="{&quot;no_create&quot;: True, &quot;no_open&quot;: True}"
                       placeholder="Assign to team member..."/>
            </xpath>

            <!-- Add Lead Source after team_id -->
            <xpath expr="//field[@name='team_id']" position="after">
                <field name="source_id"
                       string="Lead Source"
                       options="{&quot;no_create&quot;: True}"
                       placeholder="Select lead source..."/>
            </xpath>

            <!-- Add Job Title after email_from -->
            <xpath expr="//field[@name='email_from']" position="after">
                <field name="function"
                       string="Job Title"
                       placeholder="e.g. Purchase Manager"/>
            </xpath>

            <!-- NEW TAB: Opportunity Details after lead tab -->
            <xpath expr="//page[@name=&apos;lead&apos;]" position="after">
                <page string="Opportunity Details" name="x_opportunity_details">
                    <group>
                        <group string="Classification">
                            <field name="x_customer_type"   string="Customer Type"/>
                            <field name="x_purchase_timeline" string="Purchase Timeline"/>
                            <field name="priority"           string="Priority" widget="priority"/>
                        </group>
                        <group string="Product Interest">
                            <field name="x_product_category_ids"
                                   string="Product Categories"
                                   widget="many2many_tags"
                                   options="{&quot;no_create_edit&quot;: True}"
                                   placeholder="Select categories..."/>
                            <field name="x_lead_age_days" string="Lead Age (Days)" readonly="1"/>
                            <field name="x_is_overdue"    string="Overdue 30+ Days" readonly="1"/>
                        </group>
                    </group>
                    <group string="Refusal History" invisible="not x_refused_by_id">
                        <group>
                            <field name="x_refused_by_id" readonly="1" string="Refused By"/>
                            <field name="x_refuse_date"   readonly="1" string="Refused On"/>
                        </group>
                        <group>
                            <field name="x_refuse_reason" readonly="1" string="Reason"/>
                            <field name="x_is_refused"    readonly="1" string="Currently Refused"/>
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>


    <!-- ==============================================================
         OPPORTUNITIES TREE VIEW
    =============================================================== -->
    <record id="view_crm_lead_tree_oppor_custom" model="ir.ui.view">
        <field name="name">crm.lead.tree.oppor.custom</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name=&apos;user_id&apos;]" position="after">
                <field name="x_assign_to_id"     string="Assigned To"   optional="show"/>
                <field name="x_customer_type"    string="Customer Type" optional="show"/>
                <field name="x_purchase_timeline" string="Timeline"     optional="show"/>
            </xpath>
        </field>
    </record>


    <!-- ==============================================================
         SEARCH VIEW
    =============================================================== -->
    <record id="view_crm_lead_search_oppor_custom" model="ir.ui.view">
        <field name="name">crm.lead.search.oppor.custom</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_opportunities_filter"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name=&apos;my_leads&apos;]" position="after">
                <filter string="Refused"
                        name="x_refused"
                        domain="[(&#39;x_is_refused&#39;, &#39;=&#39;, True)]"/>
                <filter string="Overdue (30+ days)"
                        name="x_overdue"
                        domain="[(&#39;x_is_overdue&#39;, &#39;=&#39;, True)]"/>
                <separator/>
                <field name="x_assign_to_id"         string="Assigned To"/>
                <field name="x_product_category_ids" string="Product Category"/>
            </xpath>
        </field>
    </record>


    <!-- ==============================================================
         REFUSE WIZARD FORM VIEW
    =============================================================== -->
    <record id="view_crm_lead_refuse_wizard_form" model="ir.ui.view">
        <field name="name">crm.lead.refuse.wizard.form</field>
        <field name="model">crm.lead.refuse.wizard</field>
        <field name="arch" type="xml">
            <form string="Refuse Lead Assignment">
                <sheet>
                    <div class="oe_title">
                        <h2>Refuse This Assignment</h2>
                        <p class="text-muted">
                            Your reason will be saved on the lead and the
                            owner will receive a notification activity.
                        </p>
                    </div>
                    <group>
                        <field name="lead_id"       readonly="1" string="Lead / Opportunity"/>
                        <field name="refuse_reason"
                               string="Reason for Refusal"
                               placeholder="e.g. Not in my territory, wrong product category..."
                               required="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm_refuse"
                            string="Confirm Refusal"
                            type="object"
                            class="btn-primary"
                            data-hotkey="q"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
