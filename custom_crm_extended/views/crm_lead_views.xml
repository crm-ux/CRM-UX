<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Priority: remove star field + orphan labels (labels without field cause 422).
        Show x_priority_selection dropdown (Low / Medium / High).
    -->
    <record id="crm_lead_form_hide_default_priority" model="ir.ui.view">
        <field name="name">crm.lead.form.hide.default.priority</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="priority">9999</field>
        <field name="arch" type="xml">

            <!-- Orphan labels break Odoo 17 validation if priority field was replaced/hidden -->
            <xpath expr="//label[@for='priority']" position="replace"/>

            <!-- Assignment section -->
            <xpath expr="//group[@string='ASSIGNMENT']//field[@name='priority']" position="replace">
                <field name="x_priority_selection" string="Priority"/>
            </xpath>
            <xpath expr="//group[@string='Assignment']//field[@name='priority']" position="replace">
                <field name="x_priority_selection" string="Priority"/>
            </xpath>

            <!-- Next to Assign To -->
            <xpath expr="//field[@name='x_assign_to_id']/following-sibling::field[@name='priority']" position="replace">
                <field name="x_priority_selection" string="Priority"/>
            </xpath>

            <!-- Header / other star widgets -->
            <xpath expr="//field[@name='priority'][@widget='priority']" position="replace">
                <field name="x_priority_selection" string="Priority"/>
            </xpath>

        </field>
    </record>

</odoo>
