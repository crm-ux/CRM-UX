.crm-pro-dashboard {
    min-height: 100vh;
    padding: 28px;
    background: linear-gradient(135deg, #eef6ff 0%, #f7fbff 45%, #ffffff 100%);
    font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.crm-pro-hero {
    background: linear-gradient(135deg, #0b3d91 0%, #1769aa 55%, #2f9fd0 100%);
    border-radius: 18px;
    padding: 28px 32px;
    color: #fff;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 18px 42px rgba(11, 61, 145, 0.22);
    margin-bottom: 26px;
}

.crm-pro-kicker {
    letter-spacing: 1.8px;
    font-size: 12px;
    font-weight: 700;
    opacity: 0.86;
    margin-bottom: 8px;
}

.crm-pro-hero h1 {
    margin: 0;
    font-size: 30px;
    font-weight: 800;
}

.crm-pro-hero p {
    margin: 8px 0 0;
    font-size: 14px;
    opacity: 0.9;
}

.crm-primary-btn {
    background: #fff;
    color: #0b3d91;
    border: 0;
    border-radius: 10px;
    padding: 12px 18px;
    font-weight: 800;
    cursor: pointer;
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.14);
}

.crm-primary-btn:hover {
    background: #eaf4ff;
}

.crm-pro-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(280px, 1fr));
    gap: 20px;
}

.crm-pro-panel {
    background: #fff;
    border: 1px solid #dbeafe;
    border-radius: 16px;
    padding: 22px;
    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.08);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
}

.crm-pro-panel:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 38px rgba(15, 23, 42, 0.12);
}

.crm-lead-panel {
    border-top: 4px solid #0b3d91;
}

.crm-panel-head {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    align-items: flex-start;
    margin-bottom: 20px;
}

.crm-panel-head > div {
    display: flex;
    align-items: center;
    gap: 12px;
}

.crm-panel-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: linear-gradient(135deg, #dbeafe, #eff6ff);
    color: #0b3d91;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
}

.crm-panel-head h2 {
    margin: 0;
    color: #0f172a;
    font-size: 18px;
    font-weight: 800;
}

.crm-panel-head button {
    border: 1px solid #1d4ed8;
    color: #1d4ed8;
    background: #fff;
    border-radius: 9px;
    padding: 8px 12px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
}

.crm-panel-head button:hover {
    background: #1d4ed8;
    color: #fff;
}

.crm-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 16px;
}

.crm-pro-panel:not(.crm-lead-panel) .crm-metrics {
    grid-template-columns: 1fr;
}

.crm-metric {
    background: #f8fbff;
    border: 1px solid #e0efff;
    border-radius: 12px;
    padding: 14px;
}

.crm-metric strong {
    display: block;
    color: #0b3d91;
    font-size: 28px;
    line-height: 1;
    font-weight: 900;
}

.crm-metric span {
    display: block;
    margin-top: 7px;
    color: #64748b;
    font-size: 13px;
    font-weight: 600;
}

.crm-panel-note {
    color: #64748b;
    font-size: 13px;
    margin: 0;
    line-height: 1.5;
}

@media (max-width: 900px) {
    .crm-pro-dashboard {
        padding: 16px;
    }

    .crm-pro-hero {
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
    }

    .crm-pro-grid {
        grid-template-columns: 1fr;
    }

    .crm-metrics {
        grid-template-columns: 1fr;
    }
}
