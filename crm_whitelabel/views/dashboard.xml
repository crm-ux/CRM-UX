<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Dashboard Action -->
    <record id="action_crm_dashboard" model="ir.actions.client">
        <field name="name">Dashboard</field>
        <field name="tag">crm_dashboard</field>
    </record>

    <!-- Dashboard Menu -->
    <record id="menu_crm_dashboard" model="ir.ui.menu">
        <field name="name">Dashboard</field>
        <field name="sequence">1</field>
        <field name="action" ref="action_crm_dashboard"/>
    </record>

    <!-- Hide default home -->
    <record id="base.action_client_base_menu" model="ir.actions.client">
        <field name="tag">crm_dashboard</field>
    </record>
</odoo>
