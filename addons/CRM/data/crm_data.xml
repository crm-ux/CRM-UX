<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             UTM Sources – used for auto-priority onchange
             noupdate=1 so they are not recreated on module upgrade
        ============================================================ -->
        <record id="utm_source_referral" model="utm.source">
            <field name="name">Referral</field>
        </record>
        <record id="utm_source_direct" model="utm.source">
            <field name="name">Direct Visit</field>
        </record>
        <record id="utm_source_social" model="utm.source">
            <field name="name">Social Media</field>
        </record>
        <record id="utm_source_email_campaign" model="utm.source">
            <field name="name">Email Campaign</field>
        </record>
        <record id="utm_source_exhibition" model="utm.source">
            <field name="name">Exhibition / Trade Show</field>
        </record>
        <record id="utm_source_cold_call" model="utm.source">
            <field name="name">Cold Call</field>
        </record>
        <record id="utm_source_website" model="utm.source">
            <field name="name">Website / Enquiry Form</field>
        </record>
        <record id="utm_source_partner" model="utm.source">
            <field name="name">Channel Partner</field>
        </record>

    </data>
</odoo>
