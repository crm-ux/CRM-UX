<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_exhibition_contact_form" model="ir.ui.view">
        <field name="name">exhibition.contact.form</field>
        <field name="model">exhibition.contact</field>
        <field name="arch" type="xml">
            <form string="Exhibition Contact">
                <header>
                    <button name="action_convert_to_lead" string="Convert to Lead" type="object" class="btn-success" invisible="crm_lead_id != False"/>
                    <button name="action_convert_to_lead" string="View Linked Lead" type="object" class="btn-secondary" invisible="not crm_lead_id"/>
                </header>
                <sheet>
                    <group>
                        <group string="Contact Info">
                            <field name="contact_name"/>
                            <field name="company_name"/>
                            <field name="designation"/>
                            <field name="exhibition_name"/>
                            <field name="exhibition_date"/>
                            <field name="website"/>
                        </group>
                        <group string="Visiting Card">
                            <field name="visiting_card" widget="image" options="{'size': [300, 200]}" string="Upload Visiting Card"/>
                            <field name="visiting_card_filename" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Phone Numbers">
                            <field name="phone_ids">
                                <list editable="bottom">
                                    <field name="phone"/>
                                    <field name="phone_type"/>
                                </list>
                            </field>
                        </page>
                        <page string="Email Addresses">
                            <field name="email_ids">
                                <list editable="bottom">
                                    <field name="email"/>
                                    <field name="email_type"/>
                                </list>
                            </field>
                        </page>
                        <page string="Address">
                            <group>
                                <field name="address"/>
                                <field name="city"/>
                                <field name="x_state"/>
                                <field name="country"/>
                            </group>
                        </page>
                        <page string="Notes">
                            <field name="notes" placeholder="Add notes about this contact..."/>
                        </page>
                    </notebook>
                    <group invisible="not crm_lead_id">
                        <field name="crm_lead_id" string="Linked CRM Lead" readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_exhibition_contact_list" model="ir.ui.view">
        <field name="name">exhibition.contact.list</field>
        <field name="model">exhibition.contact</field>
        <field name="arch" type="xml">
            <list string="Exhibition Contacts">
                <field name="contact_name"/>
                <field name="company_name"/>
                <field name="designation"/>
                <field name="exhibition_name"/>
                <field name="exhibition_date"/>
                <field name="crm_lead_id"/>
            </list>
        </field>
    </record>

    <record id="view_exhibition_contact_search" model="ir.ui.view">
        <field name="name">exhibition.contact.search</field>
        <field name="model">exhibition.contact</field>
        <field name="arch" type="xml">
            <search string="Search Exhibition Contacts">
                <field name="contact_name"/>
                <field name="company_name"/>
                <field name="exhibition_name"/>
                <filter string="Converted" name="filter_converted" domain="[('crm_lead_id','!=',False)]"/>
                <filter string="Not Converted" name="filter_not_converted" domain="[('crm_lead_id','=',False)]"/>
            </search>
        </field>
    </record>

    <record id="action_exhibition_contact" model="ir.actions.act_window">
        <field name="name">Exhibition Contacts</field>
        <field name="res_model">exhibition.contact</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_exhibition_contact_search"/>
    </record>
</odoo>
