<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <menuitem id="menu_exhibition_root"
              name="Customer Database"
              sequence="50"
              web_icon="exhibition_contacts,static/src/img/icon.png"/>

    <menuitem id="menu_exhibition_contacts"
              name="Contacts"
              parent="menu_exhibition_root"
              action="action_exhibition_contact"
              sequence="10"/>

    <record id="view_exhibition_category_list" model="ir.ui.view">
        <field name="name">exhibition.category.list</field>
        <field name="model">exhibition.category</field>
        <field name="arch" type="xml">
            <list string="Categories" editable="bottom">
                <field name="name"/>
                <button name="action_delete_category" string="" type="object" icon="fa-trash" class="btn-danger btn-sm" title="Delete"/>
            </list>
        </field>
    </record>

    <record id="view_exhibition_category_form" model="ir.ui.view">
        <field name="name">exhibition.category.form</field>
        <field name="model">exhibition.category</field>
        <field name="arch" type="xml">
            <form string="Category">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_exhibition_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">exhibition.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_exhibition_category"
              name="Categories"
              parent="menu_exhibition_root"
              action="action_exhibition_category"
              sequence="20"/>
</odoo>
