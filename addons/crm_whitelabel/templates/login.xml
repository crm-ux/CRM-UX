<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="login_custom" name="CRM Login Branding"
              inherit_id="web.login" priority="20">

        <!-- SAFE branding (no form break) -->
        <xpath expr="//form" position="before">
            <div class="text-center mb-4">
                <div style="width:60px;height:60px;background:#1A56DB;border-radius:14px;display:inline-flex;align-items:center;justify-content:center;margin-bottom:10px;">
                    <span style="color:white;font-size:26px;font-weight:800;">C</span>
                </div>
                <div style="font-size:24px;font-weight:800;color:#1A56DB;">CRM Pro</div>
                <div style="font-size:12px;color:#64748B;margin-top:2px;">
                    Sales and Lead Management
                </div>
            </div>
        </xpath>

    </template>
</odoo>
