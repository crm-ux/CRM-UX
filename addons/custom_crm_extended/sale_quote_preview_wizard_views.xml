<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_quote_preview" model="report.paperformat">
        <field name="name">Quote Preview A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">25</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">5</field>
    </record>
    <record id="action_report_sale_quote_preview_wizard" model="ir.actions.report">
        <field name="name">Edited Quotation PDF</field>
        <field name="model">sale.quote.preview.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_crm_extended.report_sale_quote_preview_wizard</field>
        <field name="report_file">custom_crm_extended.report_sale_quote_preview_wizard</field>
        <field name="print_report_name">'Edited Quotation - %s' % (object.quote_name or '')</field>
        <field name="paperformat_id" ref="paperformat_quote_preview"/>
    </record>
    <template id="report_sale_quote_preview_wizard">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="comp" t-value="doc.sudo().order_id.company_id"/>
                <div class="header" style="width:100%;text-align:right;padding:2mm 0 1mm 0;border:none !important;">
                    <t t-if="comp.logo_web">
                        <img t-att-src="'data:image/png;base64,' + (comp.logo_web.decode('utf-8') if isinstance(comp.logo_web, bytes) else comp.logo_web)"
                             style="max-height:80px;max-width:220px;object-fit:contain;"/>
                    </t>
                </div>
                <main style="width:100%;">
                    <div class="page" style="font-family:Calibri,sans-serif;font-size:11px;">
                        <t t-out="doc.sudo().document_html"/>
                    </div>
                </main>
            </t>
        </t>
    </template>
</odoo>
