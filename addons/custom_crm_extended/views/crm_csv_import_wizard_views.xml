<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_crm_lead_csv_import_wizard_form" model="ir.ui.view">
        <field name="name">crm.lead.csv.import.wizard.form</field>
        <field name="model">crm.lead.csv.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Products from CSV">
                <sheet>
                    <div class="oe_title">
                        <h2>Import Product Lines from CSV</h2>
                    </div>

                    <div class="alert alert-info" role="alert">
                        <i class="fa fa-info-circle me-1"/>
                        <strong>Required CSV columns:</strong>
                        product_code, product_name
                        <br/>
                        <strong>Optional columns:</strong>
                        make, qty, unit_price, notes
                        <br/>
                        <span class="text-muted" style="font-size:12px">
                            Lines are matched first by Product ID (internal reference),
                            then by name. Unmatched lines are imported as manual entries.
                        </span>
                    </div>

                    <group>
                        <field name="lead_id"     readonly="1" string="Lead"/>
                        <field name="csv_file"    string="CSV File"
                               filename="csv_filename" required="1"/>
                        <field name="csv_filename" invisible="1"/>
                    </group>

                    <!-- Live preview after file upload -->
                    <group string="Preview (first 10 rows)"
                           invisible="not preview_html">
                        <field name="preview_html" nolabel="1" readonly="1"/>
                    </group>

                </sheet>
                <footer>
                    <button name="action_import"
                            string="Import"
                            type="object"
                            class="btn-primary"
                            data-hotkey="q"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
