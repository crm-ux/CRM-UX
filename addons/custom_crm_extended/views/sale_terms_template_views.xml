<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_terms_template_list" model="ir.ui.view">
        <field name="name">sale.terms.condition.list</field>
        <field name="model">sale.terms.condition</field>
        <field name="arch" type="xml">
            <list string="Terms &amp; Conditions">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="content"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_sale_terms_template_form" model="ir.ui.view">
        <field name="name">sale.terms.condition.form</field>
        <field name="model">sale.terms.condition</field>
        <field name="arch" type="xml">
            <form string="Terms &amp; Condition">
                <sheet>
                    <group>
                        <field name="name" string="Title"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                    <field name="content" string="Content" widget="text"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sale_terms_template" model="ir.actions.act_window">
        <field name="name">Terms &amp; Conditions</field>
        <field name="res_model">sale.terms.condition</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
