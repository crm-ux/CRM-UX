<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_form_custom" model="ir.ui.view">
        <field name="name">sale.order.form.custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state'][@widget='statusbar']" position="replace">
                <field name="state" widget="statusbar" statusbar_visible="draft"/>
            </xpath>
            <!-- Remove show_address from Customer field — show only company name -->
            <xpath expr="//group[@name='partner_details']/field[@name='partner_id']" position="attributes">
                <attribute name="context">{'res_partner_search_mode': 'customer', 'show_address': 1, 'show_vat': True}</attribute>
            </xpath>
            <!-- Contact Person below Customer -->
            <xpath expr="//group[@name='partner_details']/field[@name='partner_id']" position="after">
                <field name="x_contact_person_id" string="Contact Person" options="{'no_create': True, 'no_open': True}" domain="[('parent_id', '=', partner_id), ('is_company', '=', False)]" context="{'partner_display_name_hide_company': True}"/>
            </xpath>

            <!-- Hide Confirm button (draft state, no id) -->
            <xpath expr="//button[@name='action_confirm'][@data-hotkey='q'][not(@id)]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Confirm button (sent state, id=action_confirm) -->
            <xpath expr="//button[@id='action_confirm']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Send button (draft state, id=quotation_send_primary) -->
            <xpath expr="//button[@id='quotation_send_primary']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Cancel button -->
            <xpath expr="//button[@name='action_cancel']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Preview button -->
            <xpath expr="//button[@name='action_preview_sale_order'][not(@class='btn-primary')]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Print button -->
            <xpath expr="//button[@name='sale.action_report_saleorder']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Send button (sent/sale state) -->
            <xpath expr="//button[@id='quotation_send']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Add our custom buttons -->
            <xpath expr="//header" position="inside">

                <button name="action_preview_sale_order" string="Preview" type="object" class="btn-primary"/>
                <button name="action_print_custom_pdf" string="Print" type="object" class="btn-secondary"/>
                <button name="action_quotation_send" string="Send" type="object"
                        context="{'validate_analytic': True, 'check_document_layout': True}"
                        class="btn-secondary"/>
                <button name="action_lock_final_quote" string="Lock" type="object"
                        class="btn-secondary"
                        invisible="x_final_quote_locked"/>
                <button name="action_apply_overall_discount" string="Apply" type="object"
                        class="btn-secondary" title="Apply GST and Discount to lines" invisible="1"/>
                <button name="action_mark_won" string="Won" type="object"
                        class="btn-success"
                        invisible="x_quote_stage == 'won'"/>
                <button name="action_mark_lost" string="Lost" type="object"
                        class="btn-danger"
                        invisible="x_quote_stage == 'lost'"/>
            </xpath>

            <xpath expr="//field[@name='validity_date']" position="after">
                <field name="x_gst_included" string="Include GST" widget="boolean_toggle"/>
                <field name="x_show_cost_profit" string="Show Margin" widget="boolean_toggle"/>
            </xpath>

            <xpath expr="//field[@name='order_line']//list//field[@name='product_template_id']" position="attributes">
                <attribute name="column_invisible">1</attribute>
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//list//field[@name='product_id']" position="attributes">
                <attribute name="string">Product ID</attribute>
                <attribute name="optional">show</attribute>
                <attribute name="width">110px</attribute>
                <attribute name="context">{'show_code_only': True, 'default_lst_price': price_unit, 'default_uom_id': product_uom_id, 'partner_id': parent.partner_id}</attribute>
                <attribute name="options">{'no_create': True, 'no_open': True, 'show_label_warning': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//list//field[@name='product_id']" position="after">
                <field name="x_product_name_m2o" string="Product Name" optional="show" width="200px"
                       options="{'no_create': True, 'no_open': True}"
                       context="{'show_code_only': False}"/>
                <field name="x_hsn_code" string="HSN/SAC" optional="show" readonly="1" width="90px"/>
                <field name="x_make" string="Make / Brand" optional="show" readonly="1" width="110px"/>
            </xpath>
            <xpath expr="//field[@name='order_line']//list//field[@name='discount']" position="attributes">
                <attribute name="string">Discount %</attribute>
                <attribute name="widget">percentage</attribute>
                <attribute name="optional">show</attribute>
                <attribute name="groups">base.group_user</attribute>
            </xpath>

            <!-- Hide Taxes column when Include GST is OFF -->
            <xpath expr="//field[@name='order_line']//list//field[@name='tax_ids']" position="attributes">
                <attribute name="column_invisible">not parent.x_gst_included</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//list//field[@name='name']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//list//field[@name='price_total'][1]" position="after">
                <field name="x_notes" string="Notes" optional="show"/>
                                <field name="x_cost" string="Cost" optional="hide" groups="base.group_system"
                       column_invisible="not parent.x_show_cost_profit"/>
                <field name="x_profit" string="Profit" optional="hide" readonly="1" groups="base.group_system"
                       column_invisible="not parent.x_show_cost_profit"/>
                <field name="x_profit_pct" string="Margin %" optional="hide" readonly="1" groups="base.group_system"
                       column_invisible="not parent.x_show_cost_profit"/>
                <field name="x_technical_specs" string="Technical Specs" optional="show"/>
                <field name="x_product_image" string="Product Image" widget="image" optional="hide"/>
            </xpath>
            <xpath expr="//page[@name='order_lines']" position="after">
                <page string="PO and Handoff" name="x_po_handoff">
                    <group>
                        <group string="Purchase Order">
                            <field name="x_po_number" string="PO Number"/>
                            <field name="x_po_date" string="PO Date"/>
                            <field name="x_po_file" string="PO Document" filename="x_po_filename" widget="binary"/>
                            <field name="x_final_quote_locked" string="Final Quote Locked" readonly="1"/>
                            <field name="x_sales_order_number" string="Sales Order No"/>
                        </group>
                        <group string="Handoff">
                            <field name="x_assigned_to_service" string="Service Member" options="{'no_create': True}"/>
                            <field name="x_assigned_to_aftersales" string="After Sales" options="{'no_create': True}"/>
                            <field name="x_handoff_date" string="Handoff Date" readonly="1"/>
                            <field name="x_invoice_number" string="Invoice No"/>
                            <field name="x_invoice_date" string="Invoice Date"/>
                        </group>
                    </group>
                    <group>
                        <field name="x_service_remarks" string="Remarks for Service Team"/>
                    </group>
                </page>
                <page string="Internal Remarks" name="x_internal_remarks_tab">
                    <field name="x_internal_remarks" nolabel="1" placeholder="Notes visible to sales team only..."/>
                </page>
                <page string="Discounts" name="x_discounts_tab">
                    <group>
                        <field name="x_flat_discount_pct" string="Overall Discount (%)"/>
                        <field name="x_flat_discount" string="Flat Discount (Amount)"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Show discount in totals -->
    <record id="view_sale_order_discount_totals" model="ir.ui.view">
        <field name="name">sale.order.discount.totals</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='sale_total']" position="before">

            </xpath>
        </field>
    </record>

    <template id="sale_report_discount_format" inherit_id="sale.report_saleorder_document">
        <xpath expr="//td[@name='td_product_priceunit']" position="replace">
            <td name="td_product_priceunit" class="text-end text-nowrap">
                <t t-if="not collapse_prices and line.discount > 0">
                    <span t-esc="int(line.price_unit)"/>(<span t-esc="int(line.discount)"/>%)=<span t-esc="int(line.price_unit * line.discount / 100)"/>
                </t>
                <t t-elif="not collapse_prices">
                    <span t-esc="int(line.price_unit)"/>
                </t>
            </td>
        </xpath>
        <xpath expr="//td[@name='td_product_discount']" position="replace">
            <td t-if="display_discount" name="td_product_discount"/>
        </xpath>
    </template>
    <!-- Lost Reason Popup -->
    <record id="view_sale_order_lost_reason_form" model="ir.ui.view">
        <field name="name">sale.order.lost.reason.form</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <form string="Mark as Lost">
                <group>
                    <field name="x_lost_reason" required="1"/>
                </group>
                <footer>
                    <button name="action_confirm_lost" string="Confirm Lost" type="object" class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>