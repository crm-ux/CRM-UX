<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_default_signature" model="ir.ui.view">
        <field name="name">res.company.form.default.signature</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Default Quotation Signature Card">
                    <field name="x_default_signature_card" widget="image" options="{'size': [350, 200]}"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
