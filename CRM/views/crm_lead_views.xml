<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==============================================================
         1.  FORM VIEW  –  inherit crm.lead.form  (Opportunities)
         View ref: crm.crm_lead_all_leads (leads) + crm.crm_lead_view_form (opportunities)
         We inherit the base form which serves both.
    =============================================================== -->
    <record id="view_crm_lead_form_custom" model="ir.ui.view">
        <field name="name">crm.lead.form.custom</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">

            <!-- ========================================================
                 A.  STATUS BAR – inject "Refused" indicator after stage
            ========================================================= -->
            <xpath expr="//header" position="inside">
                <!-- Refusal alert banner – only shows when refused -->
                <div class="alert alert-warning mb-0 py-1 px-2"
                     invisible="not x_is_refused"
                     role="alert"
                     style="font-size:13px;">
                    <i class="fa fa-exclamation-triangle"/> &#160;
                    <strong>Assignment Refused</strong> by
                    <field name="x_refused_by_id" readonly="1" nolabel="1" class="oe_inline"/>
                    on <field name="x_refuse_date" readonly="1" nolabel="1" class="oe_inline"/>.
                    Reason: <field name="x_refuse_reason" readonly="1" nolabel="1" class="oe_inline"/>
                </div>
            </xpath>

            <!-- ========================================================
                 B.  BUTTONS – Add Refuse & Reset buttons in header
            ========================================================= -->
            <xpath expr="//header/button[last()]" position="after">

                <!-- Refuse button: visible to assigned user only, lead not yet refused -->
                <button name="action_refuse_lead"
                        string="Refuse Assignment"
                        type="object"
                        class="btn-secondary"
                        invisible="not x_assign_to_id or x_is_refused or x_assign_to_id != uid"
                        confirm="Are you sure you want to refuse this assignment? Your reason will be sent to the lead owner."/>

                <!-- Reset button: visible to owner when lead is refused -->
                <button name="action_reset_from_refusal"
                        string="Reset Lead"
                        type="object"
                        class="btn-secondary"
                        invisible="not x_is_refused"/>

            </xpath>

            <!-- ========================================================
                 C.  TOP SECTION – Lead title area
                     Add "Assign To" field right after the Salesperson field
            ========================================================= -->
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="x_assign_to_id"
                       string="Assign To"
                       readonly="x_assign_to_readonly"
                       options="{'no_create': True, 'no_open': True}"
                       placeholder="Assign to team member..."/>
            </xpath>

            <!-- ========================================================
                 D.  LEAD SOURCE  –  already exists as source_id in UTM tab.
                     Move/show it prominently right after team_id in header area.
            ========================================================= -->
            <xpath expr="//field[@name='team_id']" position="after">
                <field name="source_id"
                       string="Lead Source"
                       options="{'no_create': True}"
                       placeholder="Select lead source..."/>
            </xpath>

            <!-- ========================================================
                 E.  CONTACT INFO TAB  –  add custom fields after existing
                     contact block (partner_name / contact_name / email / phone)
            ========================================================= -->

            <!-- After the email_from field, add Job Title if not already shown -->
            <xpath expr="//field[@name='email_from']" position="after">
                <field name="function"
                       string="Job Title"
                       placeholder="e.g. Purchase Manager"/>
            </xpath>

            <!-- ========================================================
                 F.  NEW TAB  –  "Opportunity Details"
                     Insert after the default "Extra Info" tab.
                     Contains all our custom qualification fields.
            ========================================================= -->
            <xpath expr="//notebook" position="inside">

                <page string="Opportunity Details" name="x_opportunity_details">
                    <group>

                        <!-- Col 1: Customer & Classification -->
                        <group string="Classification">
                            <field name="x_customer_type"
                                   string="Customer Type"
                                   widget="radio"
                                   required="0"/>
                            <field name="x_purchase_timeline"
                                   string="Purchase Timeline"/>
                            <field name="priority"
                                   string="Priority"
                                   widget="priority"/>
                        </group>

                        <!-- Col 2: Product Interest -->
                        <group string="Product Interest">
                            <field name="x_product_category_ids"
                                   string="Product Categories"
                                   widget="many2many_tags"
                                   options="{'color_field': 'color', 'no_create_edit': True}"
                                   placeholder="Select categories..."/>
                            <field name="x_lead_age_days"
                                   string="Lead Age (Days)"
                                   readonly="1"/>
                            <field name="x_is_overdue"
                                   string="Overdue (30+ days)"
                                   readonly="1"
                                   widget="boolean_toggle"/>
                        </group>

                    </group>

                    <!-- Assignment & Refusal info group (full width) -->
                    <group string="Assignment History" invisible="not x_refused_by_id">
                        <group>
                            <field name="x_refused_by_id"   readonly="1" string="Refused By"/>
                            <field name="x_refuse_date"     readonly="1" string="Refused On"/>
                        </group>
                        <group>
                            <field name="x_refuse_reason"   readonly="1" string="Refusal Reason"/>
                            <field name="x_is_refused"      readonly="1" string="Currently Refused"/>
                        </group>
                    </group>

                </page>

            </xpath>

            <!-- ========================================================
                 G.  KANBAN quick-info: lead age indicator color
                     (handled via CSS class on overdue boolean)
            ========================================================= -->

        </field>
    </record>



    <!-- ==============================================================
         3.  LIST / TREE VIEW  –  add key custom columns
    =============================================================== -->
    <record id="view_crm_lead_tree_custom" model="ir.ui.view">
        <field name="name">crm.lead.tree.custom</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <!-- Add Assign To and Customer Type columns after Salesperson -->
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="x_assign_to_id" string="Assigned To" optional="show"/>
                <field name="x_customer_type" string="Customer Type" optional="show"/>
                <field name="x_purchase_timeline" string="Timeline" optional="show"/>
            </xpath>
            <!-- Lead age at the end -->
            <xpath expr="//field[@name='activity_ids']" position="before">
                <field name="x_lead_age_days" string="Age (Days)" optional="show"/>
            </xpath>
        </field>
    </record>


    <!-- ==============================================================
         4.  KANBAN VIEW  –  show assigned-to and customer type on card
    =============================================================== -->
    <record id="view_crm_lead_kanban_custom" model="ir.ui.view">
        <field name="name">crm.lead.kanban.custom</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_kanban_view"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <!-- Load our fields so they're available in kanban -->
            <xpath expr="//kanban" position="inside">
                <field name="x_assign_to_id"/>
                <field name="x_customer_type"/>
                <field name="x_is_refused"/>
                <field name="x_is_overdue"/>
                <field name="x_purchase_timeline"/>
                <field name="x_lead_age_days"/>
            </xpath>
        </field>
    </record>


    <!-- ==============================================================
         5.  SEARCH VIEW  –  add filters for our custom fields
    =============================================================== -->
    <record id="view_crm_lead_search_custom" model="ir.ui.view">
        <field name="name">crm.lead.search.custom</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_lead_filter"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='my_leads']" position="after">

                <!-- Quick filters -->
                <filter string="Refused Leads"
                        name="x_refused"
                        domain="[('x_is_refused', '=', True)]"/>
                <filter string="Overdue Leads"
                        name="x_overdue"
                        domain="[('x_is_overdue', '=', True)]"/>
                <separator/>

                <!-- Searchable fields -->
                <field name="x_assign_to_id" string="Assigned To"/>
                <field name="x_product_category_ids" string="Product Category"/>

                <!-- Group By options -->
                <filter string="Customer Type"
                        name="group_customer_type"
                        context="{'group_by': 'x_customer_type'}"/>
                <filter string="Assigned To"
                        name="group_assign_to"
                        context="{'group_by': 'x_assign_to_id'}"/>
                <filter string="Purchase Timeline"
                        name="group_timeline"
                        context="{'group_by': 'x_purchase_timeline'}"/>

            </xpath>
        </field>
    </record>


    <!-- ==============================================================
         6.  REFUSE WIZARD VIEW
    =============================================================== -->
    <record id="view_crm_lead_refuse_wizard_form" model="ir.ui.view">
        <field name="name">crm.lead.refuse.wizard.form</field>
        <field name="model">crm.lead.refuse.wizard</field>
        <field name="arch" type="xml">
            <form string="Refuse Lead Assignment">
                <sheet>
                    <div class="oe_title">
                        <h2>Refuse This Assignment</h2>
                        <p class="text-muted">
                            Providing a reason helps the lead owner understand
                            and reassign this opportunity. The reason will be
                            recorded and visible on the lead.
                        </p>
                    </div>
                    <group>
                        <field name="lead_id" readonly="1" string="Lead / Opportunity"/>
                        <field name="refuse_reason"
                               string="Reason for Refusal"
                               placeholder="e.g. Not in my territory, wrong product category, already handled by colleague..."
                               required="1"
                               nolabel="0"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm_refuse"
                            string="Confirm Refusal"
                            type="object"
                            class="btn-primary"
                            data-hotkey="q"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
